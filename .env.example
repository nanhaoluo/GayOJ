# gayoj local development configuration.
# Copy this file to .env before running Docker Compose or custom local ports.

# Runtime
GAYOJ_ENV=development
GAYOJ_SECRET_KEY=dev-only-replace-with-a-random-token
GAYOJ_TOKEN_TTL_HOURS=12
GAYOJ_OFFLINE_PACK_SECRET=dev-only-replace-with-offline-pack-secret
GAYOJ_OFFLINE_PACK_TTL_HOURS=168
GAYOJ_API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Online judge queue and worker-node heartbeat
GAYOJ_JUDGE_QUEUE_BACKEND=json
GAYOJ_JUDGE_QUEUE_TOPIC=gayoj.judge.submissions
GAYOJ_REDIS_URL=
GAYOJ_KAFKA_BOOTSTRAP_SERVERS=
GAYOJ_JUDGE_NODE_TOKEN=dev-only-replace-with-judge-node-token
GAYOJ_JUDGE_NODE_HEARTBEAT_TTL_SECONDS=60

# Code problem test-data object storage. Local mode stores ZIP objects under apps/api/storage/objects.
GAYOJ_OBJECT_STORAGE_BACKEND=local
GAYOJ_OBJECT_STORAGE_BUCKET=gayoj-testdata
GAYOJ_LOCAL_OBJECT_STORAGE_DIR=
GAYOJ_MINIO_ENDPOINT=127.0.0.1:9000
GAYOJ_MINIO_ACCESS_KEY=minioadmin
GAYOJ_MINIO_SECRET_KEY=minioadmin
GAYOJ_MINIO_SECURE=false
GAYOJ_TESTDATA_MAX_ARCHIVE_MB=50
GAYOJ_TESTDATA_MAX_UNCOMPRESSED_MB=200
GAYOJ_TESTDATA_MAX_FILES=1000

# PostgreSQL migration target. JSON storage remains the default local runtime.
GAYOJ_DATABASE_URL=postgresql://gayoj:gayoj@127.0.0.1:5432/gayoj

# Local npm development commands
GAYOJ_API_HOST=127.0.0.1
GAYOJ_API_PORT=8000
GAYOJ_API_RELOAD=true
GAYOJ_WEB_HOST=127.0.0.1
GAYOJ_WEB_PORT=5173
GAYOJ_WEB_PREVIEW_PORT=4173
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
VITE_API_BASE_URL=/api/v1

# API and CLI smoke targets
GAYOJ_API_BASE=http://127.0.0.1:8000/api/v1
GAYOJ_HEALTH_URL=http://127.0.0.1:8000/health
GAYOJ_CLI_API_BASE=http://127.0.0.1:8000/api/v1
GAYOJ_TOKEN=

# Docker Compose host ports
GAYOJ_COMPOSE_API_PORT=8000
GAYOJ_COMPOSE_WEB_PORT=8080
